# App
PORT=5000
# NODE_ENV=local | development | production
NODE_ENV=development

# CORS (multiple origins, comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
DB_HOST=localhost            # dev/prod: AWS RDS endpoint
DB_PORT=3306
DB_USERNAME=root             # dev: root_dev
DB_PASSWORD=your_password
DB_DATABASE=todo_db          # dev: todo_dev, prod: todo_prod

# Rate Limit
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# GitHub MCP (untuk akses shared context)
# Buat token di: https://github.com/settings/tokens → scope: repo
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
